{
  "name": "@idp/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "node --env-file=.env node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node --env-file=.env node_modules/drizzle-kit/bin.cjs migrate",
    "db:studio": "node --env-file=.env node_modules/drizzle-kit/bin.cjs studio",
    "db:push": "node --env-file=.env node_modules/drizzle-kit/bin.cjs push"
  },
  "dependencies": {
    "@fastify/cookie": "^9.3.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "argon2": "^0.44.0",
    "awilix": "^10.0.2",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.30.10",
    "fastify": "^4.27.0",
    "ioredis": "^5.3.2",
    "jose": "^6.2.2",
    "mongodb": "^6.6.1",
    "nanoid": "^5.0.7",
    "pino": "^9.1.0",
    "pino-pretty": "^11.0.0",
    "postgres": "^3.4.4",
    "zod": "^3.23.6"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "drizzle-kit": "^0.21.4",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}